NEXT_PUBLIC_FB_API_KEY=여기에_apiKey_붙여넣기
NEXT_PUBLIC_FB_AUTH_DOMAIN=프로젝트ID.firebaseapp.com
NEXT_PUBLIC_FB_PROJECT_ID=프로젝트ID
NEXT_PUBLIC_FB_STORAGE_BUCKET=프로젝트ID.appspot.com
NEXT_PUBLIC_FB_MESSAGING_SENDER_ID=숫자ID
NEXT_PUBLIC_FB_APP_ID=1:숫자:web:해시

# 이 파일을 .env.local 로 복사한 뒤 실제 값을 채우세요.
# Firebase 콘솔 → 프로젝트 설정 → 내 앱 → 구성에서 복사

# ── 서버 전용(src/app/api/notify/route.ts) — 없으면 알림 메일 발송이 조용히 실패한다 ──
# Resend API 키 (https://resend.com 대시보드에서 발급)
RESEND_API_KEY=re_여기에_붙여넣기
# 발신자 표시 이름/주소 — alsco.co.kr 도메인이 Resend 에서 인증되지 않았다면 onboarding@resend.dev 사용
RESEND_FROM=작업허가서 시스템 <onboarding@resend.dev>
# 담당자 이메일을 찾지 못했을 때(또는 각종 fallback) 보낼 기본 관리자 주소
NOTIFY_EMAIL=seungjung.kim@alsco.co.kr
# 공장장 최종결재 요청 메일 수신자 — 미설정 시 NOTIFY_EMAIL 로 대체 발송된다(로그로만 경고).
FACTORY_EMAIL=
# 알림 메일의 "결재/확인하기" 버튼이 가리킬 배포된 앱 URL
NEXT_PUBLIC_APP_URL=https://work-approved.vercel.app

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function myUser() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    // 계정이 차단되지 않았는가. status 없는 legacy 계정은 grace 로 통과.
    function accountActive() {
      return request.auth != null && myUser().get('status', 'active') == 'active';
    }

    function isAdmin() {
      return request.auth != null &&
        myUser().role == 'admin' && accountActive();
    }

    // 요청자(게스트)가 승인된 활성 계정인가. status 없는 legacy 계정은 grace 로 통과.
    function requesterActive() {
      return request.auth != null && accountActive();
    }

    // 게스트 계정은 이메일 인증을 강제(서버측). 레거시 가짜 도메인 계정 등 게스트가 아닌
    // 역할은 클라이언트 정책(AccessGate)과 동일하게 이 검사를 면제한다.
    function requesterVerified() {
      return request.auth != null &&
        (myUser().get('role', '') != 'guest' || request.auth.token.get('email_verified', false) == true);
    }

    // 관리자(manager)가 이 permit 의 결재 라인에 속하는가.
    //  - requester(담당자): 자신이 담당자(data.manager)인 건
    //  - factory(공장장): 자기 차례(stage=factory) 또는 완료(approved/completed)된 건만
    //  (환경안전 단계 및 전체 조회는 시스템관리자(admin) 가 담당 — isAdmin)
    function isChainManager(permit) {
      return request.auth != null
        && myUser().get('role', '') == 'manager'
        && accountActive()
        && (
          (myUser().get('managerKind', '') == 'factory'
            && (permit.data.get('stage', '') == 'factory'
                || permit.data.get('status', '') in ['approved', 'completed']))
          || (myUser().get('managerKind', '') == 'requester'
              && myUser().get('managerName', '') == permit.data.get('data', {}).get('manager', ''))
        );
    }

    // 결재 관련 protected 필드(발급/검토/승인 서명·메타) — 소유자(업체)는 절대 변경 불가.
    // chainAction(Cloud Function, admin SDK)만 이 필드들을 쓴다.
    function permitAdminFieldsLocked() {
      return request.resource.data.get('data', {}).get('admin', {}) == resource.data.get('data', {}).get('admin', {})
        && request.resource.data.get('data', {}).get('hotFireManager', '') == resource.data.get('data', {}).get('hotFireManager', '')
        && request.resource.data.get('data', {}).get('hotFireManagerSign', '') == resource.data.get('data', {}).get('hotFireManagerSign', '');
    }

    // 소유자가 바꿀 수 있는 stage/chain 전이: 같은 상태로 저장(둘 다 불변) 이거나,
    // draft/rejected → submitted 로 제출할 때만 stage='manager' + chain 초기화 허용.
    // (그 외 단계 전이는 전부 chainAction 전용 — admin SDK 는 rules 를 우회하므로 여기선 소유자만 막으면 된다.)
    function permitSubmitTransitionOk() {
      return (request.resource.data.status == resource.data.status
                && request.resource.data.get('stage', null) == resource.data.get('stage', null)
                && request.resource.data.get('chain', {}) == resource.data.get('chain', {}))
          || (request.resource.data.status == 'submitted'
                && request.resource.data.get('stage', '') == 'manager'
                && request.resource.data.get('chain', {}) == {});
    }

    // 사용자 프로필
    match /users/{uid} {
      function isSelf() { return request.auth != null && request.auth.uid == uid; }

      allow read: if isSelf() || isAdmin();
      // 셀프 회원가입: role 은 반드시 guest, 최초 status 는 pending 강제 (자가 활성/승격 차단)
      allow create: if isSelf()
        && request.resource.data.role == 'guest'
        && request.resource.data.status == 'pending';
      // 수정 시 role/status 변경 금지 (자가 승인·권한 상승 차단). 승인/차단은 Cloud Function(admin SDK)이 처리.
      // .get(...,default) 로 status 없는 legacy 문서에서도 평가 에러 없이 동작.
      allow update: if isSelf()
        && request.resource.data.role == resource.data.role
        && request.resource.data.get('status', 'active') == resource.data.get('status', 'active');
      allow delete: if false;
    }

    // 작업허가서
    match /permits/{id} {
      function isOwner() {
        return request.auth != null && resource.data.createdBy == request.auth.uid;
      }

      allow read: if isAdmin() || isOwner()
        || (isChainManager(resource) && resource.data.status != 'draft');

      // 생성: 본인 소유 + 최초 상태는 draft 로 고정 + 승인된 활성 계정 + (게스트는) 이메일 인증 필요
      allow create: if request.auth != null
        && requesterActive()
        && requesterVerified()
        && request.resource.data.createdBy == request.auth.uid
        && request.resource.data.status == 'draft';

      // 수정:
      //  - 관리자: 전체 허용 (승인/반려/완료 등)
      //  - 작성자 본인: draft/rejected 상태일 때만, createdBy 변경 불가,
      //    상태는 draft/submitted 로만 이동 가능(approved/completed 자가 설정 차단),
      //    결재 서명·메타(data.admin/hotFireManager*)는 절대 변경 불가,
      //    stage/chain 은 제출 전이(→submitted, stage='manager') 외에는 불변(단계 건너뛰기 차단)
      allow update: if isAdmin()
        || (isOwner()
            && requesterActive()
            && requesterVerified()
            && resource.data.status in ['draft', 'rejected']
            && request.resource.data.createdBy == resource.data.createdBy
            && request.resource.data.status in ['draft', 'submitted']
            && permitAdminFieldsLocked()
            && permitSubmitTransitionOk());

      allow delete: if isAdmin();
    }

    // 작업형태별 예시 양식 (게스트는 불러오기만, 관리자만 작성/수정/삭제)
    match /permitTemplates/{id} {
      allow read: if request.auth != null;
      allow write: if isAdmin();
    }

    // 작업형태별 JSA 레퍼런스 (게스트는 불러오기만, 관리자만 작성/수정/삭제)
    match /jsaReferences/{wt} {
      allow read: if request.auth != null;
      allow write: if isAdmin();
    }

    // 앱 운영 설정 (첨부 필요 서류 안내 등) — 로그인 사용자 읽기, 관리자만 쓰기
    match /appConfig/{id} {
      allow read: if request.auth != null;
      allow write: if isAdmin();
    }
  }
}
